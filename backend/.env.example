# D METRAN ERP — Backend / hybrid cloud environment
# Copy to backend/.env and adjust before production.

NODE_ENV=production
PORT=5000

# Required — generate a long random string (never use default-secret in production)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=24h

# PostgreSQL (managed DB or docker-compose service)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=d_metran_erp
DB_USER=postgres
DB_PASSWORD=change-me

# Hybrid cloud: serve React build from Express (same URL for UI + API)
SERVE_FRONTEND=true
# FRONTEND_DIST=/app/frontend/dist

# Behind nginx / load balancer with HTTPS (required for rate limit + HTTPS)
# LAN office setup: keep false — do not send HSTS (breaks http://192.168.x.x:5000)
TRUST_PROXY=false

# Comma-separated allowed browser origins (dev + production URLs)
# Use * only for local testing — not recommended in production
CORS_ORIGINS=https://erp.yourcompany.com,http://localhost:5173

# Login brute-force protection
LOGIN_RATE_WINDOW_MS=900000
LOGIN_RATE_MAX=20

# File uploads (logos, attachments)
UPLOAD_DIR=uploads
